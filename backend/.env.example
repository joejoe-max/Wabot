# WaBot Backend — environment variables
# Copy to .env and fill in all values before starting the server

# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── App URLs ─────────────────────────────────────────────────────
# Your frontend base URL (used in verification emails & CORS)
APP_BASE_URL=http://localhost:5000
API_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5000

# ── Auth ──────────────────────────────────────────────────────────
# Strong random secret for JWT signing (32+ chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Supabase ──────────────────────────────────────────────────────
# Found in: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-role-key

# ── Brevo (email) ─────────────────────────────────────────────────
# Optional in development — signup at https://app.brevo.com
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hello@yourdomain.com
BREVO_SENDER_NAME=WaBot

# ── Stripe (billing) ──────────────────────────────────────────────
# Optional — only needed when enabling paid plans
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_GROWTH=price_...
