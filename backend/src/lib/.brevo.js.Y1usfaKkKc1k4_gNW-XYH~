import { env } from "../config/env.js";

export async function sendVerificationEmail(toEmail, verifyUrl) {
  if (!env.hasBrevo) {
    console.log(`[dev] Email not sent (Brevo not configured). Verify URL: ${verifyUrl}`);
    return;
  }

  const response = await fetch("https://api.brevo.com/v3/smtp/email", {
    method: "POST",
    headers: { "Content-Type": "application/json", "api-key": env.brevoApiKey },
    body: JSON.stringify({
      sender: { name: env.brevoSenderName, email: env.brevoSenderEmail },
      to: [{ email: toEmail }],
      subject: "Verify your WaBot account",
      htmlContent: `
<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head>
<body style="margin:0;padding:0;background:#0a0a0f;font-family:Inter,system-ui,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#0a0a0f;padding:40px 20px;">
    <tr><td align="center">
      <table width="100%" style="max-width:520px;background:#111118;border:1px solid rgba(255,255,255,0.07);border-radius:16px;overflow:hidden;">
        <tr>
          <td style="background:#a855f7;padding:24px;text-align:center;">
            <span style="font-size:2rem;">🤖</span>
            <div style="color:white;font-size:1.25rem;font-weight:800;margin-top:8px;">WaBot</div>
          </td>
        </tr>
        <tr>
          <td style="padding:32px;color:#eeeeff;">
            <h2 style="margin:0 0 12px;font-size:1.25rem;font-weight:700;">Verify your email address</h2>
            <p style="margin:0 0 24px;color:#8880a8;line-height:1.7;font-size:0.9375rem;">
              You're almost ready to start deploying WhatsApp bots.
              Click the button below to verify your email and activate your WaBot account.
            </p>
            <table cellpadding="0" cellspacing="0"><tr><td>
              <a href="${verifyUrl}"
                style="display:inline-block;background:#a855f7;color:white;
                       text-decoration:none;padding:12px 28px;border-radius:100px;font-weight:700;font-size:0.9375rem;">
                Verify my account
              </a>
            </td></tr></table>
            <p style="margin:24px 0 0;font-size:0.8125rem;color:#48446a;">
              Or copy this link:<br>
              <a href="${verifyUrl}" style="color:#a855f7;word-break:break-all;">${verifyUrl}</a>
            </p>
            <p style="margin:16px 0 0;font-size:0.8125rem;color:#48446a;">
              This link expires in 24 hours. If you didn't create a WaBot account, ignore this email.
            </p>
          </td>
        </tr>
        <tr>
          <td style="padding:16px 32px;border-top:1px solid rgba(255,255,255,0.07);color:#48446a;font-size:0.75rem;">
            © ${new Date().getFullYear()} WaBot · WhatsApp Bot Platform
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>`
    })
  });

  if (!response.ok) {
    const errorText = await response.text();
    throw new Error(`Email delivery failed: ${errorText}`);
  }
}
